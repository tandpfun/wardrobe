# --- OpenAI (server-side only; never exposed to the browser) ---------------
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
# Optional per-stage overrides (fall back to OPENAI_IMAGE_MODEL):
# OPENAI_GARMENT_MODEL=
# OPENAI_MODELED_MODEL=
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# --- Local dev only (Vite middleware; not used on Vercel) ------------------
# Add a PNG at data/model-reference.png or point to another local file.
WARDROBE_MODEL_REFERENCE=data/model-reference.png

# --- Vercel production functions (api/) ------------------------------------
# Shared app passcode. Required for the deployed app to allow any access
# (fail-closed: unset => every request returns 503). Never shipped to client.
APP_PASSCODE=
# Independent HMAC signing key for session cookies. If unset, a key is derived
# from APP_PASSCODE. Set this so rotating the passcode doesn't invalidate the
# secret (and vice versa). Generate with: openssl rand -hex 32
AUTH_SECRET=
# Durable storage. Set automatically by the linked Vercel Blob store. When
# present the functions use Vercel Blob; otherwise they fall back to the local
# filesystem under WARDROBE_DATA_DIR (dev/tests only).
BLOB_READ_WRITE_TOKEN=
# WARDROBE_DATA_DIR=data
