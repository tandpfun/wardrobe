OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
# Set true only for compatible gateways that reject the Images output_format field.
OPENAI_OMIT_IMAGE_OUTPUT_FORMAT=false

# Optional read-only Immich photo picker. Keep the API key in a separate,
# gitignored file; recommended permissions: asset.read, asset.view, asset.download.
IMMICH_BASE_URL=
IMMICH_API_KEY_FILE=.secrets/immich-api-key
IMMICH_YEARS=4

# Add a PNG at data/model-reference.png or choose one through Immich.
WARDROBE_MODEL_REFERENCE=data/model-reference.png
