# --- OpenAI (server-side only; never exposed to the browser) ---------------
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
# Optional per-stage overrides (fall back to OPENAI_IMAGE_MODEL):
# OPENAI_GARMENT_MODEL=
# OPENAI_MODELED_MODEL=
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# --- Local dev only (Vite middleware; not used on Vercel) ------------------
# Add a PNG at data/model-reference.png or point to another local file.
WARDROBE_MODEL_REFERENCE=data/model-reference.png

# --- Vercel production functions (api/) ------------------------------------
# Shared app passcode. Required for the deployed app to allow any access
# (fail-closed: unset => every request returns 503). Never shipped to client.
APP_PASSCODE=
# Independent HMAC signing key for session cookies. If unset, a key is derived
# from APP_PASSCODE. Set this so rotating the passcode doesn't invalidate the
# secret (and vice versa). Generate with: openssl rand -hex 32
AUTH_SECRET=
# Durable PRIVATE storage (required in production). Objects are written with
# `access: 'private'` and read only through the authenticated Blob SDK; no Blob
# URL/token/store id is ever sent to the browser. On Vercel with NO private
# store configured, every data request FAILS CLOSED with a 503 (the ephemeral
# serverless filesystem is never used as a silent fallback).
#
# Choose ONE of the two auth modes:
#
# (a) Read-write token — for local `vercel dev` and for the admin bulk-import
#     CLI. Provided when you link a Blob store, or copy it from the store's
#     settings.
BLOB_READ_WRITE_TOKEN=
#
# (b) Vercel OIDC — preferred for the connected deployment. Vercel injects
#     VERCEL_OIDC_TOKEN automatically for connected projects; set BLOB_STORE_ID
#     to the private store's id. When both are present they take precedence over
#     BLOB_READ_WRITE_TOKEN.
# VERCEL_OIDC_TOKEN=
# BLOB_STORE_ID=
#
# Local dev / tests only: filesystem store base dir (never used on Vercel).
# WARDROBE_DATA_DIR=data
